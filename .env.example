# All values are optional — the app runs with sensible defaults without a .env file.

# Pre-fills the login form (default: 192.168.88.1)
# MIKROTIK_HOST=192.168.88.1

# RouterOS API port (default: 8728)
# MIKROTIK_PORT=8728

# Default UI language: en, ko, zh, ja (default: en)
# DEFAULT_LOCALE=en

# Flask session key — auto-generated and saved to .secret_key on first run if not set
# SECRET_KEY=change-me-to-a-random-secret-key

# HTTP port (default: 5000)
# PORT=5000

# Set to 1 to enable Flask debug mode (default: 0)
# FLASK_DEBUG=0
